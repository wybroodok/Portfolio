# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env

# Токен бота от @BotFather (команда /newbot). Обязательно.
BOT_TOKEN=

# Telegram ID администратора(ов) через запятую, без пробелов. Обязательно.
# Свой ID можно узнать у бота @userinfobot.
ADMIN_IDS=

# Часовой пояс салона (влияет на "сегодня", напоминания, блокировку дня).
# Любой ключ из базы IANA/zoneinfo. По умолчанию — Europe/Moscow.
TIMEZONE=Europe/Moscow

# Публичный HTTPS-адрес, на котором открывается мини-апп (см. README.md,
# раздел "Деплой"). Нужен для кнопки "Открыть приложение" в сообщениях бота.
# Пока не задеплоено — можно оставить пустым, бот будет слать сообщения без кнопки.
WEBAPP_URL=

# Порт, на котором локально слушает FastAPI (бэкенд + API мини-аппа).
API_PORT=8000
